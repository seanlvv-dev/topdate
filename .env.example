# TopDate 环境变量配置
# 复制此文件为 .env 并修改实际值

# JWT 密钥（请改为随机字符串）
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# 数据库连接
# SQLite (开发环境)
DATABASE_URL=sqlite+aiosqlite:///./topdate.db
# PostgreSQL (生产环境)
# DATABASE_URL=postgresql+asyncpg://topdate:topdate123@localhost:5432/topdate

# Redis (可选，用于缓存和session)
REDIS_URL=redis://localhost:6379/0

# 邮件服务配置 (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@topdate.cn

# 匹配定时任务配置
MATCHING_CRON_DAY=2    # 0=周一, 2=周三, 6=周日
MATCHING_CRON_HOUR=18  # 下午6点
MATCHING_CRON_MINUTE=0
TOP_MATCHES_PER_USER=5

# CORS 允许的前端域名
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
